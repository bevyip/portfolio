{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }],
  "functions": {
    "api/generate-flower.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "server/assets/**"
    },
    "api/flowers.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
